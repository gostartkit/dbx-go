{
  "version": 1,
  "name": "create_database_with_user",
  "category": "database",
  "tags": ["grant", "tenant"],
  "description": "Create a database, create a same-name MySQL user, and grant privileges on that database.",
  "transaction": true,
  "match": {
    "command": "create database",
    "driver": "mysql"
  },
  "inputs": [
    {
      "name": "database",
      "type": "identifier",
      "prompt": "Database name"
    },
    {
      "name": "charset",
      "type": "select",
      "prompt": "Charset",
      "default": "utf8mb4",
      "options": ["utf8mb4", "utf8"]
    },
    {
      "name": "collation",
      "type": "select",
      "prompt": "Collation",
      "default": "utf8mb4_unicode_ci",
      "options": [
        "utf8mb4_unicode_ci",
        "utf8mb4_general_ci",
        "utf8_unicode_ci",
        "utf8_general_ci"
      ]
    },
    {
      "name": "user_host",
      "type": "string",
      "prompt": "User host",
      "default": "%"
    },
    {
      "name": "password",
      "type": "secret",
      "prompt": "New user password"
    }
  ],
  "actions": [
    {
      "type": "sql",
      "description": "Create database `{{database}}`",
      "sql": "CREATE DATABASE IF NOT EXISTS `{{database}}` CHARACTER SET {{charset}} COLLATE {{collation}}"
    },
    {
      "type": "sql",
      "description": "Create user `{{database}}`@`{{user_host}}`",
      "sql": "CREATE USER IF NOT EXISTS '{{database}}'@'{{user_host}}' IDENTIFIED BY '{{password}}'"
    },
    {
      "type": "sql",
      "description": "Grant all privileges on `{{database}}` to `{{database}}`@`{{user_host}}`",
      "sql": "GRANT ALL PRIVILEGES ON `{{database}}`.* TO '{{database}}'@'{{user_host}}'"
    }
  ]
}
